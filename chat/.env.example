# Build pipeline (all optional — defaults live in src/portfolio_rag/config.py)
RAG_CHUNK_SIZE="800"
RAG_CHUNK_OVERLAP="100"

# Cloudflare Worker secrets are NOT set through .env files.
# After `cd chat/worker`, set them with wrangler so they never touch the repo:
#   npx wrangler secret put ANTHROPIC_API_KEY
# Non-secret worker vars (model name, allowed origins) live in worker/wrangler.toml.
